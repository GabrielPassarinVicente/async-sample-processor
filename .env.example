# =========================================
# .env.example — copie para .env e ajuste
# cp .env.example .env
# =========================================
# Esses valores funcionam direto com o Docker Compose.
# Para rodar localmente sem Docker, veja as instruções no README.

# ---- Backend ----
ASPNETCORE_ENVIRONMENT=Development

# ---- RabbitMQ ----
RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_QUEUE=log_notifications

# ---- Frontend ----
# URL que o Nuxt/Axios usará para chamar a API .NET
NUXT_PUBLIC_API_BASE=http://localhost:8080

# ---- Portas dos serviços (Docker) ----
BACKEND_PORT=8080
FRONTEND_PORT=3000

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost